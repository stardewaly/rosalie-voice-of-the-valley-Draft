      "Target": "Data/mail",
      "Entries": {
        "stardewaly.rosalie_SaloonRampMail": "{{i18n:SaloonRampMail}} %item conversationTopic stardewaly.rosalie_RosalieRamp 1 %%[#]A Family Matter - Gus",
        "stardewaly.rosalie_WelcomeRosalieMail": "{{i18n:WelcomeRosalieMail}} %item conversationTopic stardewaly.rosalie_NPCRosalieArrivalCT 7 %%[#]A New Resident - Mayor Lewis",
        "{{ModId}}_RosaliesRadioRobinLetter": "{{i18n:RobinsLetter-VOTVRadio}} %item conversationTopic {{ModId}}_RosalieVOTVJobEventCT 7 %%[#]Supporting Local Radiowaves - Robin", //CT not implemented yet

        "{{ModId}}_RosaliesQuestLetter": "{{i18n:RosaliesMushroomQuest.Letter}} %item quest RosaliesMushroomQuest true %%[#]A Quest from Rosalie",
        "stardewaly.rosalie_VOTVInvite": "{{i18n:VoiceOfTheValleyLive.Invite}} %%[#]Voice Of The Valley Invite"
        
      }
    },

    /* NOTE:(Works with MailFlag put into Appearences in content.json, did not see if CTs worked as was not implemented yet in dialogue)*/

    {
      "LogName": "Rosalie Mail Flags",
      "Action": "EditData",
      "Target": "Data/mail",
      "Entries": {
        "stardewaly.rosalie_RosalieWCFlag": "%action Spiderbuttons.BETAS_UpdateAppearance {{ModId}}_Rosalie {{ModId}}_Rosalie_WC %%",
        "stardewaly.rosalie_RosalieFlareUpFlag": "%action AddConversationTopic stardewaly.rosalie_FlareupCT 1 %%",
        
      }
      },

           //MAIL TRIGGERS
      {"LogName": "Rosalie Actual Mail Flag Trigger Actions",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
  
        "{{ModId}}_RosalieIsComing.SaloonDelayMail": {
          "Id": "{{ModId}}_RosalieIsComing.SaloonDelayMail",
          "Trigger": "DayEnding",
          "Condition": "PLAYER_HEARTS Current Gus 1",
          "Actions": ["AddMail Current stardewaly.rosalie_SaloonRampMail tomorrow",
          "AddMail All {{ModId}}_RosalieOnHerWay received"] //Trigger for Map
        },

        "{{ModId}}_RosalieIsComing.RampEventCT": {
          "Id": "RosalieIsComingCT",
          "Trigger": "DayStarted",
          "Condition": "PLAYER_HAS_MAIL Any stardewaly.rosalie_SaloonRampMail",
          "Action": "AddConversationTopic stardewaly.rosalie_RosalieRamp 4"
        },

        "{{ModId}}_RosalieWelcomeMailArrival": {
          "Id": "Welcome Rosalie Mail - She's Here!",
          "Trigger": "DayStarted",
          "Condition": "PLAYER_HAS_SEEN_EVENT Current stardewaly.rosalie_RosalieRampEvent",
          "Action": 
            "AddMail All stardewaly.rosalie_WelcomeRosalieMail now"
          
        },

        "{{ModId}}_VoiceOfTheValleyInvite":
        {
          "Id": "Voice Of The Valley Invite",
          "Trigger": "DayEnding",
          "Condition": "PLAYER_HEARTS Current {{ModId}}_Rosalie 8",
          "Action": 
            "AddMail Current {{ModId}}_VOTVInvite now"
        },   

//NOT ACTUAL MAIL        
        "{{ModId}}_NPCRosalieArrivalCT": {
          "Id": "NPCs on Rosalie's Arrival Conversation Topic",
          "Trigger": "DayStarted",
          "Condition": "PLAYER_HAS_MAIL Current stardewaly.rosalie_WelcomeRosalieMail",
          "Action": 
            "AddConversationTopic stardewaly.rosalie_NPCRosalieArrivalCT 7"

         },


         //ADDED MAY 22

               // Hiria's 'leaving' for the dentist - she becomes invisible as soon as she arrives at the specified coordinate on the BusStop map
                "{{ModID}}_RosalieTherapy_Go": {
                    "Id": "{{ModID}}_RosalieTherapy_Go",
                    "Trigger": "Spiderbuttons.BETAS_NpcArrived",
                    "MarkActionApplied": false,
                    "Condition": "LOCATION_Name Target BusStop, ITEM_ID Target {{ModID}}_Rosalie, Spiderbuttons.BETAS_ITEM_MOD_DATA Target BETAS/NpcArrived/X 22, Spiderbuttons.BETAS_ITEM_MOD_DATA Target BETAS/NpcArrived/Y 10",
                    "Actions": [
                        "SetNpcInvisible {{ModID}}_Rosalie 1"
                    ]
                },

                // Hiria's 'return' from the dentist - she just becomes visible again. Time is set in the SpaceCore TriggerActionExtensionData edit below.
                "{{ModID}}_RosalieTherapy_Return": {
                    "Id": "{{ModID}}_RosalieTherapy_Return",
                    "Trigger": "Manual",
                    "MarkActionApplied": false,
                    "Actions": [
                        "SetNpcVisible {{ModID}}_Rosalie 2"
                    ]
                }                
            }
        },

                      // Additional code block needed to add the time for Rosalie's dentist return trigger action
    {
            "Action": "EditData",
            "Target": "spacechase0.SpaceCore/TriggerActionExtensionData",
            "Entries": {
                "{{ModID}}_RosalieTherapy_Return": {
                    "Times": [ 1150 ]


                    }
                  }
               }

      ]
      }    




